datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String          @id @default(uuid())
  name         String
  email        String          @unique
  password     String
  role         String          @default("user")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lastLogin    DateTime?
  isActive     Boolean         @default(true)
  submissions  URLSubmission[]
  reports      Report[]
  analytics    Analytics?
  activityLogs ActivityLog[]
}

model URLSubmission {
  id             String             @id @default(uuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  websiteUrl     String
  businessName   String
  priority       String             // "low" | "medium" | "high"
  status         String             @default("pending") // "pending" | "success" | "failed"
  submissionDate DateTime           @default(now())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  reports        Report[]
  jobs           AutomationJob[]
  detections     FormDetection[]
  results        SubmissionResult[]
  runs           AutomationRun[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([websiteUrl])
}

model Report {
  id                 String        @id @default(uuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissionId       String
  urlSubmission      URLSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  totalAttempts      Int           @default(0)
  successfulAttempts Int           @default(0)
  failedAttempts     Int           @default(0)
  successRate        Int           @default(0)
  createdAt          DateTime      @default(now())

  @@index([userId])
  @@index([submissionId])
}

model Analytics {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalUrls      Int       @default(0)
  successfulUrls Int       @default(0)
  failedUrls     Int       @default(0)
  successRate    Int       @default(0)
  lastUpdated    DateTime  @default(now()) @updatedAt

  @@index([userId])
}

model AutomationJob {
  id           String        @id @default(uuid())
  submissionId String
  submission   URLSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status       String        @default("pending") // "pending" | "processing" | "success" | "failed" | "retrying"
  attempts     Int           @default(0)
  maxAttempts  Int           @default(3)
  lastError    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([submissionId])
  @@index([status])
}

model FormDetection {
  id           String        @id @default(uuid())
  submissionId String
  submission   URLSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  formSelector String?
  fieldsJson   Json          // array of detected fields: { name, type, label, id, placeholder, selector, etc. }
  createdAt    DateTime      @default(now())

  @@index([submissionId])
}

model SubmissionResult {
  id               String        @id @default(uuid())
  submissionId     String
  submission       URLSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  success          Boolean
  filledFieldsJson Json          // mapped values filled: { fieldName: value }
  screenshotPath   String?       // base64 data or server file path
  errorMessage     String?
  responseStatus   Int?
  durationMs       Int?
  createdAt        DateTime      @default(now())

  @@index([submissionId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AutomationRun {
  id               String        @id @default(uuid())
  userId           String
  url              String
  submissionId     String
  submission       URLSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  startedAt        DateTime      @default(now())
  completedAt      DateTime?
  status           String        @default("pending") // "pending" | "processing" | "success" | "failed"
  success          Boolean       @default(false)
  failureReason    String?
  screenshotBefore String?       // base64 image data
  screenshotAfter  String?       // base64 image data
  submissionProof  String?
  executionTimeMs  Int?
  detectedFields   Json?
  filledFields     Json?
  submittedValues  Json?
  submitButtonUsed String?
  successMessage   String?
  redirectUrl      String?
  timestamp        DateTime      @default(now())

  @@index([userId])
  @@index([submissionId])
  @@index([status])
}

model AppointmentBooking {
  id               String   @id @default(uuid())
  userId           String
  url              String
  bookingDate      String
  bookingTime      String
  calendarProvider String
  status           String
  createdAt        DateTime @default(now())

  @@index([userId])
}


